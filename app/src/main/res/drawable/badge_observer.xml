<!--
  badge_observer.xml
  Rank Level 1 — The Observer

  Design language: A single open eye. The user is watching, not yet acting.
  Sparse, powerful, slightly unsettling. One outer ring — the lowest rank.
  Central symbol: almond eye shape + iris detail lines + solid gold pupil.

  Place this file at:
    app/src/main/res/drawable/badge_observer.xml
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="120dp"
    android:height="120dp"
    android:viewportWidth="200"
    android:viewportHeight="200">

    <!-- ── Dark background fill ─────────────────────────────────────────── -->
    <path
        android:fillColor="#0D0D0D"
        android:pathData="M100,2 A98,98 0 1,0 100,198 A98,98 0 1,0 100,2 Z" />

    <!-- ── Outer gold ring ───────────────────────────────────────────────── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#C8A84B"
        android:strokeWidth="5"
        android:pathData="M100,10 A90,90 0 1,0 100,190 A90,90 0 1,0 100,10 Z" />

    <!-- ── Subtle inner ring (thin, slightly faded) ──────────────────────── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#C8A84B"
        android:strokeWidth="1"
        android:strokeAlpha="0.35"
        android:pathData="M100,24 A76,76 0 1,0 100,176 A76,76 0 1,0 100,24 Z" />

    <!-- ── Eye outline — almond / vesica shape ──────────────────────────── -->
    <!--
        Left point: (28, 100)   Right point: (172, 100)
        Top apex:   (100, 64)   Bottom apex: (100, 136)
        Cubic bezier curves for natural eyelid curvature.
        Upper lid curves steeper (more dramatic), lower lid is flatter.
    -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#C8A84B"
        android:strokeWidth="3.5"
        android:pathData="M28,100 C52,58 148,58 172,100 C148,142 52,142 28,100 Z" />

    <!-- ── Upper eyelid crease (second curve, slightly inset and offset) ── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#C8A84B"
        android:strokeWidth="1.2"
        android:strokeAlpha="0.45"
        android:pathData="M46,86 C66,68 134,68 154,86" />

    <!-- ── Iris ring (stroke only) ───────────────────────────────────────── -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#C8A84B"
        android:strokeWidth="2.5"
        android:pathData="M74,100 A26,26 0 1,0 126,100 A26,26 0 1,0 74,100 Z" />

    <!-- ── Iris radial detail lines — 8 lines from r=15 to r=23 ─────────── -->
    <!--
        0°   right:  (115,100)→(123,100)
        45°  SE:     (111,111)→(116,116)
        90°  down:   (100,115)→(100,123)
        135° SW:     (89,111)→(84,116)
        180° left:   (85,100)→(77,100)
        225° NW:     (89,89)→(84,84)
        270° up:     (100,85)→(100,77)
        315° NE:     (111,89)→(116,84)
    -->
    <path
        android:fillColor="#00000000"
        android:strokeColor="#C8A84B"
        android:strokeWidth="1.4"
        android:strokeAlpha="0.7"
        android:pathData="
            M115,100 L123,100
            M111,111 L116,116
            M100,115 L100,123
            M89,111 L84,116
            M85,100 L77,100
            M89,89 L84,84
            M100,85 L100,77
            M111,89 L116,84" />

    <!-- ── Pupil — solid gold fill ───────────────────────────────────────── -->
    <path
        android:fillColor="#C8A84B"
        android:pathData="M87,100 A13,13 0 1,0 113,100 A13,13 0 1,0 87,100 Z" />

    <!-- ── Rank indicator bar — single bar = Level 1 ────────────────────── -->
    <path
        android:fillColor="#C8A84B"
        android:pathData="M72,162 L128,162 L128,166 L72,166 Z" />

</vector>
