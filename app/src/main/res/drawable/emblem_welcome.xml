<!--
  emblem_welcome.xml
  Welcome Screen Identity Emblem — v2

  Design language: A gold flame. Fire. The start of something.
  This is NOT a rank badge.
    - No circular background.
    - No rings, no crosshairs, no concentric circles.
  All rank badges (Observer, Initiate, Challenger, Conqueror, Sovereign) are
  circular icons. This emblem is a vertical flame shape — completely different
  in silhouette, in meaning, and in visual language.

  The flame represents:
    - Heat — the discomfort the app is built around.
    - A starting point — fire begins a journey.
    - Energy — not rank, not achievement, just raw starting potential.

  Place this file at:
    app/src/main/res/drawable/emblem_welcome.xml
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="120dp"
    android:height="120dp"
    android:viewportWidth="200"
    android:viewportHeight="200">

    <!--
      ── OUTER FLAME BODY ──────────────────────────────────────────────────────
      The main silhouette of the flame. Gold stroke, very faint warm fill.
      Uses quadratic bezier curves to get the natural teardrop-like shape.

      Path logic (starting at base centre, going counter-clockwise):
        Base centre: (100, 175)
        Left lower:  control (52, 152) → end (56, 118)   pulls wide then inward
        Left mid:    control (60, 85)  → end (72, 65)    narrows toward tip
        Left upper:  control (82, 42)  → end (100, 18)   arrives at tip
        Right upper: control (118, 42) → end (128, 65)   mirrors left
        Right mid:   control (140, 85) → end (144, 118)  mirrors left
        Right lower: control (148, 152)→ end (100, 175)  back to base
    -->
    <path
        android:fillColor="#221A0900"
        android:strokeColor="#C8A84B"
        android:strokeWidth="4"
        android:pathData="
            M100,175
            Q52,152 56,118
            Q60,85 72,65
            Q82,42 100,18
            Q118,42 128,65
            Q140,85 144,118
            Q148,152 100,175
            Z" />

    <!--
      ── INNER FLAME ───────────────────────────────────────────────────────────
      Smaller, same general shape, sits inside the outer flame.
      Warmer gold, slightly more opaque — the hotter inner part of the fire.
    -->
    <path
        android:fillColor="#33DCB65C"
        android:strokeColor="#DCB65C"
        android:strokeWidth="2.5"
        android:pathData="
            M100,158
            Q74,135 76,110
            Q80,86 90,70
            Q95,54 100,40
            Q105,54 110,70
            Q120,86 124,110
            Q126,135 100,158
            Z" />

    <!--
      ── FLAME CORE ────────────────────────────────────────────────────────────
      The bright, hot centre of the flame. Near-white to gold gradient effect
      approximated by layering a bright semi-transparent fill.
      No stroke — just a soft bright shape that bleeds into the inner flame.
    -->
    <path
        android:fillColor="#99FFF4CC"
        android:pathData="
            M100,138
            Q88,116 90,103
            Q95,87 100,72
            Q105,87 110,103
            Q112,116 100,138
            Z" />

    <!--
      ── BASE HORIZONTAL LINE ──────────────────────────────────────────────────
      A short decorative line at the base of the flame.
      Acts as a "ground" — the flame rests on this, giving it weight
      and preventing it from floating disconnected on the screen.
    -->
    <path
        android:strokeColor="#C8A84B"
        android:strokeWidth="3.5"
        android:strokeLineCap="round"
        android:fillColor="#00000000"
        android:pathData="M65,180 L135,180" />

    <!--
      ── TIP SPARKLE ───────────────────────────────────────────────────────────
      A small bright dot at the very tip of the flame.
      Represents the hottest, highest point — where the fire ends and light begins.
    -->
    <path
        android:fillColor="#FFF4CC"
        android:pathData="M97,14 A3,3 0 1,0 103,14 A3,3 0 1,0 97,14 Z" />

    <!--
      ── SIDE SPARKLES ─────────────────────────────────────────────────────────
      Two smaller accent dots flanking the tip.
      Give the flame a sense of heat and energy without added complexity.
    -->
    <path
        android:fillColor="#C8A84B"
        android:fillAlpha="0.70"
        android:pathData="M76,33 A2,2 0 1,0 80,33 A2,2 0 1,0 76,33 Z" />

    <path
        android:fillColor="#C8A84B"
        android:fillAlpha="0.70"
        android:pathData="M120,33 A2,2 0 1,0 124,33 A2,2 0 1,0 120,33 Z" />

</vector>
